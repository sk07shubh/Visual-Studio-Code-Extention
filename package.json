{
  "name": "errbuddy",
  "displayName": "ErrBuddy",
  "description": "Explains terminal errors in simple English for beginners — shows exactly where the error is, what caused it, and fixes it in one click using AI",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
],
  "main": "./extension.js",
  "contributes": {
    "commands": [
        {
            "command": "errbuddy.explain",
            "title": "ErrBuddy: Explain Error"
        }
    ],
    "keybindings": [
        {
            "command": "errbuddy.explain",
            "key": "ctrl+shift+e",
            "mac": "cmd+shift+e"
        }
    ]
},
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
